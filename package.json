{
  "name": "@gabrielcraveiro/meeting-cli",
  "version": "1.4.0",
  "description": "CLI tool for recording, transcribing, and organizing meeting notes with AI — live chat, auto-insights, and Obsidian integration",
  "author": "Gabriel Craveiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielcraveiro/meeting-cli.git"
  },
  "keywords": ["meeting", "transcription", "cli", "deepgram", "obsidian", "ai", "wasapi"],
  "bin": {
